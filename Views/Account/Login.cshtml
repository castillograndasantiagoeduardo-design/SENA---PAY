@{
    ViewData["Title"] = "Iniciar Sesión";
}

<div class="container d-flex justify-content-center align-items-center" style="min-height: 75vh;">
    <div class="card shadow border-0" style="width: 100%; max-width: 380px;">
        <div class="card-body p-4">
            <div class="text-center mb-4">
                <h2 class="fw-bold text-success">Sena-Pay</h2>
                <p class="text-muted small">Bienvenido, ingresa tus datos</p>
            </div>

            <form>
                <div class="mb-3">
                    <label class="form-label">Usuario o Correo</label>
                    <input type="text" class="form-control" placeholder="Ej: santiago@sena.edu.co">
                </div>

                <div class="mb-4">
                    <label class="form-label">Contraseña</label>
                    <input type="password" class="form-control" placeholder="••••••••">
                </div>

                <button type="button" class="btn btn-success w-100 mb-3">
                    Ingresar
                </button>

                <div class="text-center">
                    <a href="#" class="text-decoration-none small text-secondary">¿Problemas para entrar?</a>
                </div>
            </form>
        </div>
    </div>
</div>