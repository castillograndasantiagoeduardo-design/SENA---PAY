@model  Sena_Pay.Models.LoginViewModel

@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>SenaPay | Acceso Seguro</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <style>
        :root {
            --color-primario: #39A900;
            --color-glow: rgba(57, 169, 0, 0.2);
            --transition-speed: 0.5s;
        }

        body, html {
            height: 100%;
            margin: 0;
            overflow: hidden;
            font-family: 'Inter', sans-serif;
        }

        .main-wrapper {
            display: flex;
            height: 100vh;
            width: 100%;
        }

        /* SECCIÓN IZQUIERDA */
        .left-section {
            width: 40%;
            background: #ffffff;
            display: flex;
            align-items: center;
            justify-content: center;
            position: relative;
            z-index: 10;
        }

        /* LA TARJETA (Mantiene bordes redondeados de tus capturas) */
        .login-card {
            width: 100%;
            max-width: 420px;
            padding: 40px;
            background: #ffffff;
            border-radius: 30px;
            box-shadow: 0 20px 60px rgba(0,0,0,0.08);
            border: 1px solid rgba(0,0,0,0.05);
            transition: transform 0.3s ease;
        }

        /* Animación de entrada al cambiar rol */
        .fade-in-up {
            animation: fadeInUp 0.5s ease forwards;
        }

        @@keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(20px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        /* LOGO DINÁMICO */
        .brand-logo {
            width: 70px;
            height: 70px;
            background: var(--color-primario);
            border-radius: 20px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 20px;
            color: white;
            font-size: 32px;
            box-shadow: 0 10px 25px var(--color-glow);
            transition: all var(--transition-speed) ease;
        }

        .brand-name {
            color: var(--color-primario);
            font-weight: 800;
            transition: color var(--transition-speed) ease;
        }

        /* INPUTS */
        .form-label {
            font-size: 0.7rem;
            font-weight: 800;
            color: #94a3b8;
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-bottom: 6px;
        }

        .form-control, .form-select {
            border-radius: 14px;
            border: 2px solid #f1f5f9;
            padding: 12px 18px;
            transition: all 0.3s ease;
        }

            .form-control:focus, .form-select:focus {
                border-color: var(--color-primario);
                box-shadow: 0 0 0 4px var(--color-glow);
                outline: none;
                background: white;
            }

        /* BOTÓN */
        .btn-login {
            background: var(--color-primario);
            border: none;
            border-radius: 16px;
            padding: 18px;
            font-weight: 800;
            color: white;
            text-transform: uppercase;
            letter-spacing: 2px;
            box-shadow: 0 12px 24px var(--color-glow);
            transition: all var(--transition-speed) ease;
        }

            .btn-login:hover {
                filter: brightness(0.9);
                transform: translateY(-3px);
                box-shadow: 0 15px 30px var(--color-glow);
            }

        /* SECCIÓN DERECHA: ESPACIO PARA IMAGEN */
        .right-section {
            width: 60%;
            position: relative;
            background-color: var(--color-primario);
            transition: background var(--transition-speed) ease;
            overflow: hidden;
        }

        .hero-image {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: transform 1.5s ease;
            /* --- AQUÍ PEGAS TU URL --- */
            background-image: url('URL_DE_TU_IMAGEN_AQUI');
            background-size: cover;
            background-position: center;
        }

        .right-section:hover .hero-image {
            transform: scale(1.05); /* Efecto de zoom suave al pasar el mouse */
        }

        .overlay-text {
            position: absolute;
            bottom: 60px;
            left: 60px;
            color: white;
            z-index: 5;
            max-width: 500px;
            text-shadow: 0 4px 10px rgba(0,0,0,0.3);
        }
    </style>
</head>
<body>

    <div class="main-wrapper">
        <div class="left-section">
            <div class="login-card" id="cardElement">
                <div class="text-center mb-4">
                    <div class="brand-logo" id="dynamicLogo">
                        <i class="bi bi-person-badge-fill"></i>
                    </div>
                    <h2 class="fw-bold brand-name m-0 h1">SenaPay</h2>
                    <p class="text-muted small fw-bold">Ecosistema Digital de Pagos</p>
                </div>

                <form id="loginForm">
                    <div class="mb-3">
                        <label class="form-label">Rol de Usuario</label>
                        <select class="form-select" id="rolSelector" onchange="updateTheme()">
                            <option value="Aprendiz">Aprendiz</option>
                            <option value="Admin">Administrador</option>
                            <option value="SuperAdmin">Super Administrador</option>
                        </select>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Tipo Identificación</label>
                        <select class="form-select" id="tipoDoc">
                            <option value="CC">Cédula de Ciudadanía</option>
                            <option value="TI">Tarjeta de Identidad</option>
                        </select>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Documento</label>
                        <input type="text" class="form-control" placeholder="0000000000" onkeypress="return isNumberKey(event)" />
                    </div>

                    <div class="mb-4">
                        <label class="form-label">Clave de Seguridad</label>
                        <input type="password" class="form-control" placeholder="••••••••" />
                    </div>

                    <div class="d-grid">
                        <button type="button" class="btn btn-login">
                            Acceder Ahora <i class="bi bi-arrow-right-short ms-2"></i>
                        </button>
                    </div>
                </form>

                <div class="mt-5 text-center">
                    <p class="small text-muted mb-0">Tecnología desarrollada por</p>
                    <p class="fw-bold text-dark m-0">Byte Forge</p>
                </div>
            </div>
        </div>

        <div class="right-section">
            <div class="hero-image"></div>
            <div class="overlay-text">
                <h2 class="display-4 fw-bold">Transformación <br> Digital SENA</h2>
                <p class="lead">Gestiona tu identidad y tus pagos en una sola plataforma segura.</p>
            </div>
        </div>
    </div>

    <script>
        function isNumberKey(evt) {
            var charCode = (evt.which) ? evt.which : evt.keyCode;
            return !(charCode > 31 && (charCode < 48 || charCode > 57));
        }

        function updateTheme() {
            const rol = document.getElementById('rolSelector').value;
            const root = document.querySelector(':root');
            const logoIcon = document.querySelector('#dynamicLogo i');
            const card = document.getElementById('cardElement');

            const themes = {
                'Aprendiz': { 'primary': '#39A900', 'glow': 'rgba(57, 169, 0, 0.3)', 'icon': 'bi-person-badge-fill' },
                'Admin': { 'primary': '#FF6B00', 'glow': 'rgba(255, 107, 0, 0.3)', 'icon': 'bi-person-gear' },
                'SuperAdmin': { 'primary': '#6D28D9', 'glow': 'rgba(109, 40, 217, 0.3)', 'icon': 'bi-shield-lock-fill' }
            };

            const theme = themes[rol];

            // Efecto dinámico de recarga de tarjeta
            card.classList.remove('fade-in-up');
            void card.offsetWidth; // Trigger reflow
            card.classList.add('fade-in-up');

            // Cambio de variables CSS
            root.style.setProperty('--color-primario', theme.primary);
            root.style.setProperty('--color-glow', theme.glow);
            logoIcon.className = `bi ${theme.icon}`;
        }

        window.onload = updateTheme;
    </script>
</body>
</html>